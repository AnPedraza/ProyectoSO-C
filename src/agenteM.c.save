/*#######################################################################################
 * Pontificia Universidad Javeriana
 * Fecha: 2026
 * Autores: Oscar Pinilla, David Pedraza, Johan Barreto
 * Programa: agenteM.c
 *
 * Descripción:
 *   Proceso Agente de Medición. Se ejecuta de forma independiente (un proceso por
 *   estación, en terminales separadas) y realiza las siguientes tareas:
 *
 *     1. Lee línea a línea un archivo CSV de sensores meteorológicos.
 *     2. Valida que cada medición esté dentro de los rangos aceptables (Tabla 1).
 *     3. Si es válida, la transmite al Monitor a través de un Pipe Nominal (FIFO).
 *     4. Espera un tiempo configurable entre cada envío (parámetro -t).
 *     5. Al llegar al final del archivo ('.'), envía señal FIN_ al Monitor y termina.
 *
 * Formato del archivo CSV de entrada:
 *   ESTACION,HUMEDAD,ROCIO,PRESION,HH:MM:SS
 *   Ejemplo: EK,90,9,750,08:00:00
 *   La última línea que empieza con '.' indica fin del archivo de sensores.
 *
 * Correcciones aplicadas:
 *   [BUG 4] Variable 'estacion' podía contener basura si ninguna línea fue
 *           parseada antes de enviar FIN_. Ahora se guarda la estación desde
 *           el primer parseo exitoso, y como respaldo se usa el nombre del archivo.
 *
 * Invocación:
 *   ./agenteM -f <archivo_csv> -t <tiempo_seg> -p <nombre_pipe>
 *   Ejemplos:
 *     ./agenteM -f sensorKen.csv -t 1 -p pipeNom
 *     ./agenteM -p pipeNom -t 2 -f Teusaquillo.csv
 ######################################################################################*/

/* =====================================================================================
 * INCLUDES
 * ===================================================================================== */
#include <stdio.h>        // fopen, fclose, fgets, printf, fprintf, sprintf
#include <stdlib.h>       // exit, atoi
#include <string.h>       // sscanf, strcmp, strlen
#include <unistd.h>       // write, close, sleep
#include <fcntl.h>        // open, O_WRONLY
#include <getopt.h>       // getopt para parseo de flags
#include "comun.h"        // Constantes de rango y estructura Medicion
#include "validaciones.h" // Función validarRangos()

int main(int argc, char *argv[]) {

    /* -----------------------------------------------------------------------
     * Variables de configuración recibidas por argumentos de línea de comandos
     * ----------------------------------------------------------------------- */
    char *archivo = NULL;  // -f: ruta al archivo CSV de sensores
    char *pipeNom = NULL;  // -p: nombre del pipe nominal
    int tiempo    = 0;     // -t: segundos de espera entre lecturas

    int opt;

    /* -----------------------------------------------------------------------
     * Parseo de argumentos con getopt.
     *
     * La cadena "f:t:p:" indica que los tres flags aceptan argumento (':').
     * getopt permite cualquier orden de flags, cumpliendo con el requisito
     * del enunciado de que ambas invocaciones sean equivalentes:
     *   ./agenteM -f sensorKen.csv -t 1 -p pipeNom
     *   ./agenteM -p nombrePipe -t 2 -f Teusaquillo.csv
     * ----------------------------------------------------------------------- */
    while ((opt = getopt(argc, argv, "f:t:p:")) != -1) {
        switch (opt) {
            case 'f':
                archivo = optarg;      // Guardar puntero al nombre del archivo
                break;
            case 't':
                tiempo = atoi(optarg); // Convertir string a entero
                break;
            case 'p':
                pipeNom = optarg;      // Guardar puntero al nombre del pipe
                break;
            default:
                /* Argumento desconocido: mostrar uso y terminar */
                fprintf(stderr, "Uso: ./agenteM -f <archivo> -t <seg> -p <pipe>\n");
                exit(EXIT_FAILURE);
        }
    }

    /* Validar que todos los argumentos obligatorios estén presentes */
    if (!archivo || !pipeNom || tiempo <= 0) {
        fprintf(stderr, "[AGENTE] Error: Faltan argumentos o tiempo inválido.\n");
        fprintf(stderr, "Uso: ./agenteM -f <archivo> -t <seg> -p <pipe>\n");
        exit(EXIT_FAILURE);
    }

    /* -----------------------------------------------------------------------
     * Apertura del archivo CSV de sensores
     *
     * fopen en modo "r" (solo lectura). Si el archivo no existe o no puede
     * abrirse (permisos, ruta incorrecta), se reporta el error y se termina.
     * ----------------------------------------------------------------------- */
    FILE *fp = fopen(archivo, "r");
    if (!fp) {
        perror("[AGENTE] Error al abrir el archivo CSV de sensores");
        exit(EXIT_FAILURE);
    }

    /* -----------------------------------------------------------------------
     * Apertura del Pipe Nominal (FIFO) en modo solo escritura
     *
     * open() con O_WRONLY en un FIFO es BLOQUEANTE: el agente espera aquí
     * hasta que el Monitor abra el mismo FIFO en modo lectura (O_RDONLY).
     *
     * Esto garantiza sincronización de arranque: el agente no enviará datos
     * hasta que el Monitor esté listo para recibirlos.
     *
     * Si el pipe no existe (el Monitor aún no lo creó), open() falla con
     * ENOENT → verificar que el Monitor se inició primero.
     * ----------------------------------------------------------------------- */
    int fdPipe = open(pipeNom, O_WRONLY);
    if (fdPipe < 0) {
        perror("[AGENTE] Error al abrir el Pipe Nominal (¿el Monitor está corriendo?)");
        fclose(fp);
        exit(EXIT_FAILURE);
    }

    /* -----------------------------------------------------------------------
     * Variables de trabajo
     * ----------------------------------------------------------------------- */
    char linea[128];       // Buffer para leer cada línea del CSV
    char estacion[10];     // Identificador de la estación (ej: "EK", "ET")
    char hora[12];         // Marca de tiempo (formato HH:MM:SS)
    int  hum, roc, pres;  // Valores de los sensores
    char buffer_envio[256]; // Buffer para construir el mensaje a enviar por el pipe

    /*
     * [BUG 4 - CORRECCIÓN]:
     * nombre_estacion: guarda el identificador de estación encontrado en el archivo.
     * Inicializado con el nombre del archivo como respaldo de seguridad.
     *
     * En la versión anterior, la señal FIN_ usaba 'estacion' directamente,
     * que podía contener basura si ninguna línea fue parseada exitosamente
     * (por ejemplo, si todas las líneas estaban fuera de rango o malformadas).
     * Ahora se guarda el primer valor válido encontrado.
     */
    char nombre_estacion[10];
    strncpy(nombre_estacion, archivo, sizeof(nombre_estacion) - 1);
    nombre_estacion[sizeof(nombre_estacion) - 1] = '\0'; // Asegurar null terminator

    /* Bandera para saber si ya tenemos el nombre real de la estación */
    int estacion_identificada = 0;

    printf("... Agente de Medición en proceso!!!\n");
    printf("[AGENTE] Archivo: %s | Pipe: %s | Intervalo: %ds\n",
           archivo, pipeNom, tiempo);
    fflush(stdout);

    /* -----------------------------------------------------------------------
     * Ciclo principal: leer → validar → enviar
     *
     * Procesa el archivo línea por línea hasta encontrar '.' (fin de sensores)
     * o llegar al EOF.
     * ----------------------------------------------------------------------- */
    while (fgets(linea, sizeof(linea), fp)) {

        /*
         * Condición de fin de archivo del sensor: línea que comienza con '.'
         * El enunciado especifica que el agente debe esperar un tiempo adicional
         * y luego terminar enviando la señal de cierre al Monitor.
         */
        if (linea[0] == '.') {
            printf("[AGENTE] Marcador de fin '.' detectado. Esperando %ds antes de cerrar...\n",
                   tiempo);
            sleep(tiempo); // Espera adicional según el enunciado
            break;
        }

        /*
         * Parseo de la línea CSV con sscanf.
         *
         * Formato esperado: ESTACION,HUMEDAD,ROCIO,PRESION,HH:MM:SS
         *
         * %[^,] lee todos los caracteres hasta la primera coma (el nombre de estación).
         * %d lee enteros para humedad, rocío y presión.
         * %s lee la hora (cadena sin espacios).
         *
         * sscanf retorna el número de campos convertidos exitosamente.
         * Si no son exactamente 5, la línea está malformada y se ignora.
         */
        if (sscanf(linea, "%[^,],%d,%d,%d,%s",
                   estacion, &hum, &roc, &pres, hora) == 5) {

 
             * Guardar el nombre de la estación del PRIMER parseo exitoso.
             * Este valor se usará en la señal FIN_ al finalizar.
             */
            if (!estacion_identificada) {
                strncpy(nombre_estacion, estacion, sizeof(nombre_estacion) - 1);
                nombre_estacion[sizeof(nombre_estacion) - 1] = '\0';
                estacion_identificada = 1;
                printf("[AGENTE] Estación identificada: %s\n", nombre_estacion);
            }

            /*
             * Validación de rangos según Tabla 1:
             *   Humedad:  77% - 100%
             *   Presión:  740 - 760 hPa
             *   Rocío:    3°C - 12°C
             *
             * validarRangos() está implementado en validaciones.c y retorna:
             *   1 → dato válido, transmitir al Monitor
             *   0 → dato fuera de rango, descartar y reportar
             */
            if (validarRangos(hum, roc, pres)) {
                /*
                 * Dato válido: construir la trama CSV para enviar por el pipe.
                 *
                 * Se agrega '\n' al final para que el Monitor pueda tokenizar
                 * por líneas usando strtok(buffer, "\n") en el recolector.
                 * Sin este '\n', múltiples mensajes podrían fusionarse en el pipe.
                 */
                int n = sprintf(buffer_envio, "%s,%d,%d,%d,%s\n",
                                estacion, hum, roc, pres, hora);

                /*
                 * Escritura atómica en el pipe.
                 * write() en un FIFO con menos de PIPE_BUF bytes (4096 en Linux)
                 * es atómica, garantizando que el mensaje no se mezcle con los
                 * de otros agentes a nivel de bytes.
                 */
                if (write(fdPipe, buffer_envio, n) == -1) {
                    perror("[AGENTE] Error escribiendo en el pipe");
                } else {
                    printf("[AGENTE-ENVIADO] %s", buffer_envio);
                }

            } else {
                /*
                 * Dato fuera de rango: reportar en consola como alerta SCADA.
                 * El dato NO se envía al Monitor (se filtra aquí en el agente).
                 */
                printf("[SCADA - ALERTA] Datos DESCARTADOS de %s "
                       "(Fuera de rango) → H:%d R:%d P:%d\n",
                       estacion, hum, roc, pres);
            }

        } else {
            /*
             * Línea malformada (no coincide con el formato esperado).
             * Se ignora silenciosamente para no interrumpir el flujo.
             * Descomenta la siguiente línea para debug si necesitas verlas:
             * printf("[AGENTE] Línea ignorada (formato inválido): %s", linea);
             */
        }

        /*
         * Esperar el tiempo configurado antes de leer la siguiente línea.
         * Simula la cadencia real de los sensores físicos.
         */
        sleep(tiempo);
    }

    /* -----------------------------------------------------------------------
     * Protocolo de finalización: señal FIN_ al Monitor
     *
     * Cuando el agente termina su archivo, envía "FIN_<estacion>\n" por el pipe.
     * El Monitor cuenta estas señales; cuando recibe NUM_ESTACIONES (3), sabe
     * que todos los agentes han terminado y puede cerrar el sistema.
     * Se usa 'nombre_estacion' (guardado del primer parseo exitoso) en lugar de
     * 'estacion' (variable local del último sscanf, puede ser basura si el archivo
     * estaba vacío o todas las líneas eran inválidas).
     * ----------------------------------------------------------------------- */
    int n = sprintf(buffer_envio, "FIN_%s\n", nombre_estacion);
    if (write(fdPipe, buffer_envio, n) == -1) {
        perror("[AGENTE] Error enviando señal de finalización");
    } else {
        printf("[AGENTE] Señal de cierre enviada: %s", buffer_envio);
    }

    /* Mensaje de finalización requerido por el enunciado */
    printf("Fin de Lectura de Sensores de la Estación %s!!!\n", nombre_estacion);
    fflush(stdout);

    /* -----------------------------------------------------------------------
     * Liberación de recursos
     *
     * Cerrar en orden: primero el pipe (el Monitor detecta el cierre del
     * extremo de escritura), luego el archivo.
     * ----------------------------------------------------------------------- */
    close(fdPipe);  // Cerrar extremo escritura del FIFO
    fclose(fp);     // Cerrar el archivo CSV de sensores

    return 0;
}
